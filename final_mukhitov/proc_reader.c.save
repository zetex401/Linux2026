#include <fcntl.h>
#include <unistd.h>
#include <stdio.h>
#include <string.h>

int read_raw(const char *path, char *buffer, size_t size) {
    int fd = open(path, O_RDONLY);

    if (fd < 0)
        return -1;

    ssize_t bytes = read(fd, buffer, size - 1);

    close(fd);

    if (bytes < 0)
        return -1;

    buffer[bytes] = '\0';

    return 0;
}

int main() {
    char loadavg[256];
    char uptime[256];

    if (read_raw("/proc/loadavg", loadavg, sizeof(loadavg)) != 0) {
        printf("Cannot read loadavg\n");
        return 1;
    }

    if (read_raw("/proc/uptime", uptime, sizeof(uptime)) != 0) {
        printf("Cannot read uptime\n");
        return 1;
    }

    printf("=== PROC INFO ===\n");
    printf("LOADAVG:\n%s\n", loadavg);
    printf("UPTIME:\n%s\n", uptime);

    return 0;
}
